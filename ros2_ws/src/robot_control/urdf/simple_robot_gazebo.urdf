<?xml version="1.0"?>
<robot name="two_wheel_robot">

  <!-- ================= BASE LINK ================= -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.05"/>
      <mass value="4.0"/>
      <inertia ixx="0.1" ixy="0" ixz="0"
               iyy="0.1" iyz="0"
               izz="0.05"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
      <material name="base_material">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= LEFT WHEEL ================= -->
  <link name="left_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.005"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <material name="wheel_material">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= RIGHT WHEEL ================= -->
  <link name="right_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.01" iyz="0"
               izz="0.005"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <material name="wheel_material">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= CASTER WHEEL ================= -->
  <link name="caster_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0"
               iyy="0.001" iyz="0"
               izz="0.001"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
      <material name="caster_material">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
  </link>

  <!-- ================= JOINTS ================= -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.11 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="10"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.11 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="10" velocity="10"/>
  </joint>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.12 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- ================= GAZEBO PHYSICS ================= -->
  <gazebo reference="base_link">
    <mu1>0.2</mu1>
    <mu2>0.2</mu2>
    <selfCollide>false</selfCollide>
    <material>Gazebo/Blue</material>
  </gazebo>

  <gazebo reference="left_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <selfCollide>false</selfCollide>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <selfCollide>false</selfCollide>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="caster_wheel">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
    <selfCollide>false</selfCollide>
    <kp>1000000.0</kp>
    <kd>10.0</kd>
    <material>Gazebo/Grey</material>
  </gazebo>

  <!-- ================= DIFF DRIVE PLUGIN ================= -->
  <gazebo>
    <plugin name="gz::sim::systems::DiffDrive"
            filename="libgz-sim-diff-drive-system.so">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.22</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <max_linear_velocity>2.0</max_linear_velocity>
      <max_angular_velocity>4.0</max_angular_velocity>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

</robot>